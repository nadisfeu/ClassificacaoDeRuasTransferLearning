filenames[num_train : num_train + num_val]\n    test_files = image_filenames[num_train + num_val : total_needed]\n\n    splits = {\n        'train': train_files,\n        'val': val_files,\n        'test': test_files\n    }\n\n    # 6. Criar os novos diretórios e copiar os arquivos\n    for split_name, files in splits.items():\n        # Caminhos de destino para o subset atual\n        split_img_dir = os.path.join(output_base_path, split_name, 'images')\n        split_mask_dir = os.path.join(output_base_path, split_name, 'masks')\n\n        os.makedirs(split_img_dir, exist_ok=True)\n        os.makedirs(split_mask_dir, exist_ok=True)\n\n        print(f\"Copiando {len(files)} arquivos para o conjunto de '{split_name}'...\")\n\n        for filename in files:\n            # Caminhos de origem\n            src_img = os.path.join(urban_images_path, filename)\n            src_mask = os.path.join(urban_masks_path, filename)\n\n            # Caminhos de destino\n            dst_img = os.path.join(split_img_dir, filename)\n            dst_mask = os.path.join(split_mask_dir, filename)\n\n            # Copiar a imagem\n            shutil.copy2(src_img, dst_img)\n            \n            # Verificar se a máscara correspondente existe antes de copiar\n            if os.path.exists(src_mask):\n                shutil.copy2(src_mask, dst_mask)\n            else:\n                print(f\"Aviso: Máscara não encontrada para a imagem {filename}\")\n\n    print(f\"\\n✅ Organização concluída! A base reduzida está em: {output_base_path}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:09.412567Z","iopub.execute_input":"2026-06-18T17:18:09.413327Z","iopub.status.idle":"2026-06-18T17:18:10.108629Z","shell.execute_reply.started":"2026-06-18T17:18:09.413282Z","shell.execute_reply":"2026-06-18T17:18:10.107995Z"}},"outputs":[{"name":"stdout","text":"Copiando 100 arquivos para o conjunto de 'train'...\nCopiando 30 arquivos para o conjunto de 'val'...\nCopiando 3