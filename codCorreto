{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[],"dockerImageVersionId":28755,"isInternetEnabled":false,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# ==========================================\n# 0. IMPORTAÇÃO DE BIBLIOTECAS (Versão Limpa)\n# ==========================================\n\n# Bibliotecas padrão do Python\nimport os\nimport random\nimport shutil\n\n# Bibliotecas de manipulação de dados\nimport numpy as np # Álgebra linear e matrizes\nimport pandas as pd # Processamento de dados (I/O)\n\n# Biblioteca para processamento de imagens\nfrom PIL import Image\n\n# Bibliotecas para visualização gráfica\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\n\n# Integração com o Kaggle\nimport kagglehub","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:08.730395Z","iopub.execute_input":"2026-06-18T17:18:08.731128Z","iopub.status.idle":"2026-06-18T17:18:08.735471Z","shell.execute_reply.started":"2026-06-18T17:18:08.731097Z","shell.execute_reply":"2026-06-18T17:18:08.734545Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **Imagens de exemplo e labels**","metadata":{}},{"cell_type":"code","source":"def display_image_and_mask(image_path, mask_path, title_prefix=\"\"):\n    \"\"\"\n    Displays an image and its corresponding mask side-by-side.\n    \"\"\"\n    try:\n        image = Image.open(image_path).convert(\"RGB\")\n        mask = Image.open(mask_path).convert(\"L\") # Convert mask to grayscale\n\n        fig, axes = plt.subplots(1, 2, figsize=(12, 6))\n\n        axes[0].imshow(image)\n        axes[0].set_title(f\"{title_prefix}Image\")\n        axes[0].axis('off')\n\n        axes[1].imshow(mask, cmap='gray') # Display mask in grayscale\n        axes[1].set_title(f\"{title_prefix}Mask (Labels)\")\n        axes[1].axis('off')\n\n        plt.tight_layout()\n        plt.show()\n    except FileNotFoundError:\n        print(f\"Error: One or both files not found. Image: {image_path}, Mask: {mask_path}\")\n    except Exception as e:\n        print(f\"An error occurred: {e}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:08.736670Z","iopub.execute_input":"2026-06-18T17:18:08.737028Z","iopub.status.idle":"2026-06-18T17:18:08.749246Z","shell.execute_reply.started":"2026-06-18T17:18:08.736998Z","shell.execute_reply":"2026-06-18T17:18:08.748500Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Define the base path for the Urban training images and masks\nurban_images_path = '/kaggle/input/datasets/mohammedjaveed/loveda-dataset/Train/Train/Urban/images_png'\nurban_masks_path = '/kaggle/input/datasets/mohammedjaveed/loveda-dataset/Train/Train/Urban/masks_png'\n\n# Get a list of all image filenames in the Urban training set\nimage_filenames = [f for f in os.listdir(urban_images_path) if f.endswith('.png')]\n\nif image_filenames:\n    # Select a random image filename\n    random_image_filename = random.choice(image_filenames)\n\n    # Construct full paths for the selected image and its corresponding mask\n    selected_image_path = os.path.join(urban_images_path, random_image_filename)\n    # Masks often have the same filename as images, just in a different directory\n    selected_mask_path = os.path.join(urban_masks_path, random_image_filename)\n\n    print(f\"Displaying example: {random_image_filename}\")\n    display_image_and_mask(selected_image_path, selected_mask_path, title_prefix=\"Urban \")\nelse:\n    print(f\"No PNG images found in {urban_images_path}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:08.750370Z","iopub.execute_input":"2026-06-18T17:18:08.750656Z","iopub.status.idle":"2026-06-18T17:18:09.411103Z","shell.execute_reply.started":"2026-06-18T17:18:08.750621Z","shell.execute_reply":"2026-06-18T17:18:09.410219Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **2. ORGANIZAÇÃO DA BASE**\n\nUtilize um subconjunto da base LoveDA para que o treinamento possa ser feito durante o horário da aula.\n\nSugestão:\n\n- 100 imagens para treino;\n- 30 imagens para validação;\n- 30 imagens para teste.","metadata":{}},{"cell_type":"code","source":"# 1. Definir caminhos originais\nurban_images_path = '/kaggle/input/datasets/mohammedjaveed/loveda-dataset/Train/Train/Urban/images_png'\nurban_masks_path = '/kaggle/input/datasets/mohammedjaveed/loveda-dataset/Train/Train/Urban/masks_png'\n\n# 2. Definir o diretório de saída (Kaggle permite escrita na pasta /kaggle/working)\noutput_base_path = '/kaggle/working/loveda_subset'\n\n# 3. Quantidades sugeridas para a aula\nnum_train = 100\nnum_val = 30\nnum_test = 30\ntotal_needed = num_train + num_val + num_test\n\n# 4. Obter e embaralhar a lista de imagens\nimage_filenames = [f for f in os.listdir(urban_images_path) if f.endswith('.png')]\n\nif len(image_filenames) < total_needed:\n    print(f\"Erro: Não há imagens suficientes. Foram encontradas {len(image_filenames)}, mas você precisa de {total_needed}.\")\nelse:\n    # Fixar a semente aleatória garante que você pegue o mesmo subconjunto se rodar a célula de novo\n    random.seed(42) \n    random.shuffle(image_filenames)\n\n    # 5. Fazer a divisão (split) das listas\n    train_files = image_filenames[:num_train]\n    val_files = image_filenames[num_train : num_train + num_val]\n    test_files = image_filenames[num_train + num_val : total_needed]\n\n    splits = {\n        'train': train_files,\n        'val': val_files,\n        'test': test_files\n    }\n\n    # 6. Criar os novos diretórios e copiar os arquivos\n    for split_name, files in splits.items():\n        # Caminhos de destino para o subset atual\n        split_img_dir = os.path.join(output_base_path, split_name, 'images')\n        split_mask_dir = os.path.join(output_base_path, split_name, 'masks')\n\n        os.makedirs(split_img_dir, exist_ok=True)\n        os.makedirs(split_mask_dir, exist_ok=True)\n\n        print(f\"Copiando {len(files)} arquivos para o conjunto de '{split_name}'...\")\n\n        for filename in files:\n            # Caminhos de origem\n            src_img = os.path.join(urban_images_path, filename)\n            src_mask = os.path.join(urban_masks_path, filename)\n\n            # Caminhos de destino\n            dst_img = os.path.join(split_img_dir, filename)\n            dst_mask = os.path.join(split_mask_dir, filename)\n\n            # Copiar a imagem\n            shutil.copy2(src_img, dst_img)\n            \n            # Verificar se a máscara correspondente existe antes de copiar\n            if os.path.exists(src_mask):\n                shutil.copy2(src_mask, dst_mask)\n            else:\n                print(f\"Aviso: Máscara não encontrada para a imagem {filename}\")\n\n    print(f\"\\n✅ Organização concluída! A base reduzida está em: {output_base_path}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:09.412567Z","iopub.execute_input":"2026-06-18T17:18:09.413327Z","iopub.status.idle":"2026-06-18T17:18:10.108629Z","shell.execute_reply.started":"2026-06-18T17:18:09.413282Z","shell.execute_reply":"2026-06-18T17:18:10.107995Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"print(sorted(train_files))\nprint(sorted(test_files))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:10.110425Z","iopub.execute_input":"2026-06-18T17:18:10.110698Z","iopub.status.idle":"2026-06-18T17:18:10.115098Z","shell.execute_reply.started":"2026-06-18T17:18:10.110677Z","shell.execute_reply":"2026-06-18T17:18:10.114312Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":" # **3. VISUALIZAÇÃO DOS DADOS**\nAntes de treinar o modelo, visualize pelo menos 5 exemplos da base.\n\nPara cada exemplo, mostre:\n\n- imagem original;\n- máscara real;\n- legenda das classes presentes na máscara.\n\nObjetivo desta etapa:\nVerificar se as imagens e as máscaras foram carregadas corretamente.","metadata":{}},{"cell_type":"code","source":"# 1. Definir os caminhos\ntrain_img_dir = '/kaggle/working/loveda_subset/train/images'\ntrain_mask_dir = '/kaggle/working/loveda_subset/train/masks'\n\n# 2. Dicionário de Classes do LoveDA\nloveda_classes = {\n    0: ('Ignore', (255, 255, 255)),     # Branco\n    1: ('Background', (0, 0, 0)),       # Preto\n    2: ('Building', (255, 0, 0)),       # Vermelho (Construções)\n    3: ('Road', (255, 255, 0)),         # Amarelo (Vias)\n    4: ('Water', (0, 0, 255)),          # Azul (Água)\n    5: ('Barren', (159, 129, 183)),     # Roxo/Cinza (Solo exposto)\n    6: ('Forest', (0, 255, 0)),         # Verde (Floresta)\n    7: ('Agriculture', (255, 195, 128)) # Laranja (Agricultura)\n}\n\n# 3. Selecionar 5 imagens aleatórias para visualização\nimage_filenames = [f for f in os.listdir(train_img_dir) if f.endswith('.png')]\nrandom.seed(42)\namostras = random.sample(image_filenames, min(5, len(image_filenames)))\n\n# 4. Configurar a figura do Matplotlib\nfig, axes = plt.subplots(len(amostras), 2, figsize=(12, 4 * len(amostras)))\n\n# Caso seja apenas 1 amostra, ajustar matriz de eixos\nif len(amostras) == 1: \n    axes = [axes]\n\nfor i, filename in enumerate(amostras):\n    img_path = os.path.join(train_img_dir, filename)\n    mask_path = os.path.join(train_mask_dir, filename)\n\n    # Carregar imagem original em RGB\n    img = Image.open(img_path).convert('RGB')\n    \n    # Carregar a máscara sem converter! \n    mask = Image.open(mask_path)\n\n    img_np = np.array(img)\n    mask_np = np.array(mask)\n\n    # --- A. Plotar a Imagem Original ---\n    ax_img = axes[i, 0]\n    ax_img.imshow(img_np)\n    ax_img.set_title(f\"Imagem Original\\n{filename}\", fontsize=12, fontweight='bold')\n    ax_img.axis('off')\n\n    # --- B. Processar e Plotar a Máscara Real ---\n    ax_mask = axes[i, 1]\n    \n    # Criar uma tela vazia em RGB (mesmo tamanho da máscara) para pintar as cores\n    mask_colorida = np.zeros((mask_np.shape[0], mask_np.shape[1], 3), dtype=np.uint8)\n    \n    classes_presentes = np.unique(mask_np)\n    legend_patches = []\n\n    for cls_val in classes_presentes:\n        if cls_val in loveda_classes:\n            cls_name, cls_rgb = loveda_classes[cls_val]\n            \n            # Substituir os pixels da classe atual pela sua respectiva cor RGB\n            mask_colorida[mask_np == cls_val] = cls_rgb\n            \n            # O Matplotlib exige que a cor da legenda esteja normalizada entre 0 e 1\n            cor_norm = [c / 255.0 for c in cls_rgb]\n            \n            # AGORA O MPATCHES VAI FUNCIONAR CORRETAMENTE:\n            patch = mpatches.Patch(color=cor_norm, label=f\"Classe {cls_val}: {cls_name}\")\n            legend_patches.append(patch)\n\n    ax_mask.imshow(mask_colorida)\n    ax_mask.set_title(\"Máscara Real (Ground Truth)\", fontsize=12, fontweight='bold')\n    ax_mask.axis('off')\n\n    # Adicionar a legenda ao lado direito da máscara\n    ax_mask.legend(handles=legend_patches, bbox_to_anchor=(1.05, 1), loc='upper left', borderaxespad=0.)\n\n# Ajustar o layout\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:10.116037Z","iopub.execute_input":"2026-06-18T17:18:10.116334Z","iopub.status.idle":"2026-06-18T17:18:11.918614Z","shell.execute_reply.started":"2026-06-18T17:18:10.116312Z","shell.execute_reply":"2026-06-18T17:18:11.916723Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **4. PREPARAÇÃO DAS IMAGENS**\n\nPrepare as imagens antes do treinamento.\n\nRealize:\n\n- redimensionamento das imagens;\n- normalização dos pixels;\n- conversão das máscaras para o formato adequado;\n- separação entre entrada e saída.\n\nSugestão de tamanho para a atividade em sala:\n\n256 x 256 pixels\n\nEsse tamanho reduz o custo computacional e permite treinar o modelo mais rapidamente.\n","metadata":{}},{"cell_type":"code","source":"\n# Tamanho sugerido para reduzir custo computacional\nIMG_SIZE = 256\n\ndef preparar_dataset(img_dir, mask_dir):\n    X = [] # Lista para as imagens (Entradas)\n    Y = [] # Lista para as máscaras (Saídas)\n    \n    # Listar apenas os arquivos de imagem\n    filenames = [f for f in os.listdir(img_dir) if f.endswith('.png')]\n    print(f\"Processando {len(filenames)} amostras. Aguarde...\")\n    \n    for filename in filenames:\n        img_path = os.path.join(img_dir, filename)\n        mask_path = os.path.join(mask_dir, filename)\n        \n        # Carregar as imagens\n        img = Image.open(img_path).convert('RGB')\n        mask = Image.open(mask_path)\n        \n        # --- 1. REDIMENSIONAMENTO ---\n        # Imagem: Pode usar interpolação suave (Bilinear)\n        img_resized = img.resize((IMG_SIZE, IMG_SIZE), Image.Resampling.BILINEAR)\n        \n        # Máscara: DEVE usar Vizinho Mais Próximo para não misturar os valores inteiros das classes\n        mask_resized = mask.resize((IMG_SIZE, IMG_SIZE), Image.Resampling.NEAREST)\n        \n        # Converter para arrays NumPy\n        img_np = np.array(img_resized, dtype=np.float32)\n        \n        # --- 3. CONVERSÃO DAS MÁSCARAS ---\n        # Garantir que a máscara seja um array de inteiros\n        mask_np = np.array(mask_resized, dtype=np.int32)\n        \n        # --- 2. NORMALIZAÇÃO DOS PIXELS ---\n        # Dividir os pixels da imagem original (0-255) por 255.0 para escala entre 0 e 1\n        img_np = img_np / 255.0\n        \n        # --- 4. SEPARAÇÃO (Entrada e Saída) ---\n        X.append(img_np)\n        Y.append(mask_np)\n        \n    # Converter as listas finais para tensores multidimensionais do NumPy\n    X_array = np.array(X)\n    Y_array = np.array(Y)\n    \n    return X_array, Y_array\n\n# Executar a função\nX_train, y_train = preparar_dataset(train_img_dir, train_mask_dir)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:11.919882Z","iopub.execute_input":"2026-06-18T17:18:11.920256Z","iopub.status.idle":"2026-06-18T17:18:16.756589Z","shell.execute_reply.started":"2026-06-18T17:18:11.920218Z","shell.execute_reply":"2026-06-18T17:18:16.756009Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Imprimir o resumo dos dados para garantir que tudo ocorreu bem\nprint(\"\\n--- Resumo dos Dados ---\")\nprint(f\"Formato da Entrada (X_train): {X_train.shape} -> (Amostras, Altura, Largura, Canais)\")\nprint(f\"Formato da Saída   (y_train): {y_train.shape} -> (Amostras, Altura, Largura)\")\nprint(f\"Pixel mínimo de X: {X_train.min()} | Pixel máximo de X: {X_train.max()}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:16.757386Z","iopub.execute_input":"2026-06-18T17:18:16.757678Z","iopub.status.idle":"2026-06-18T17:18:16.775583Z","shell.execute_reply.started":"2026-06-18T17:18:16.757633Z","shell.execute_reply":"2026-06-18T17:18:16.774889Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# --- Visualização de Verificação (Sanity Check) ---\nfig, axes = plt.subplots(1, 2, figsize=(10, 5))\n\n# Pegar o primeiro exemplo processado\nimg_exemplo = X_train[0]\nmask_exemplo = y_train[0]\n\naxes[0].imshow(img_exemplo) \naxes[0].set_title(f\"Imagem Pré-processada\\nResolução: {img_exemplo.shape[1]}x{img_exemplo.shape[0]}\", fontweight='bold')\naxes[0].axis('off')\n\n# Usar um mapa de cores (cmap) para destacar as diferentes classes inteiras na máscara\naxes[1].imshow(mask_exemplo, cmap='nipy_spectral') \naxes[1].set_title(f\"Máscara Pré-processada\\nResolução: {mask_exemplo.shape[1]}x{mask_exemplo.shape[0]}\", fontweight='bold')\naxes[1].axis('off')\n\nplt.tight_layout()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-18T17:18:16.776906Z","iopub.execute_input":"2026-06-18T17:18:16.777203Z","iopub.status.idle":"2026-06-18T17:18:17.079700Z","shell.execute_reply.started":"2026-06-18T17:18:16.777175Z","shell.execute_reply":"2026-06-18T17:18:17.078846Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **5. MODELO COM TRANSFER LEARNING**\n\nUtilize uma arquitetura de segmentação com encoder pré-treinado.\n\nSugestões de modelos:\n\n- U-Net com encoder ResNet;\n- U-Net com encoder MobileNet;\n- DeepLabV3 com backbone ResNet;\n- SegFormer.\n\nSugestão principal para esta atividade:\n\nU-Net com encoder ResNet34 pré-treinado\n\nA ideia é usar uma rede que já aprendeu características visuais gerais, como bordas, texturas e formas, e adaptá-la para identificar elementos nas imagens da LoveDA.","metadata":{}},{"cell_type":"code","source":"# 1. Instalar a biblioteca de segmentação (caso não esteja instalada no ambiente)\n!pip install -q segmentation-models-pytorch","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import segmentation_models_pytorch as smp\nimport torch.nn as nn\n\n# 2. Definir o dispositivo (GPU se disponível, senão CPU)\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nprint(f\"Rodando o modelo no dispositivo: {device}\")\n\n# 3. Criar o modelo U-Net com o encoder sugerido\n# O LoveDA possui 8 classes (0 a 7)\nmodel = smp.Unet(\n    encoder_name=\"resnet34\",        # Encoder sugerido\n    encoder_weights=\"imagenet\",     # Pesos pré-treinados no ImageNet\n    in_channels=3,                  # Imagens de entrada RGB (3 canais)\n    classes=8                       # Quantidade de classes no dicionário loveda_classes\n)\n\n# Enviar o modelo para a memória do dispositivo correspondente\nmodel = model.to(device)\n\n# 4. Definir a Função de Perda (Loss) e o Otimizador\n# Usamos CrossEntropyLoss pois é um problema de classificação multiclasse por pixel\ncriterion = nn.CrossEntropyLoss()\noptimizer = torch.optim.Adam(model.parameters(), lr=1e-4)\n\nprint(\"✅ Modelo inicializado com sucesso e pronto para o treinamento!\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# *6. TREINAMENTO*\n\nTreine o modelo usando o subconjunto da base.\n\nConfiguração sugerida:\n\n- Épocas: 5 a 10\n- Batch size: 4, 8 ou 16\n- Otimizador: Adam\n- Função de loss: Cross-Entropy\n- Métrica principal: IoU\n\nDurante o treinamento, registre:\n\n- loss de treino;\n- loss de validação;\n- IoU de validação;\n- acurácia por pixel, se disponível.","metadata":{}},{"cell_type":"code","source":"import torch\nimport numpy as np\nfrom tqdm import tqdm\n\n# ==========================================\n# 1. CONFIGURAÇÕES ADICIONAIS DO TREINAMENTO\n# ==========================================\nnum_epochs = 5        # Recomendado de 5 a 10 para testes rápidos\nnum_classes = 8       # Definido na célula anterior do seu notebook\n\n# Certifique-se de que o nome dos seus DataLoaders estão corretos abaixo:\n# (Ajuste para 'dataloaders[\"train\"]' ou similar caso tenha usado outra nomenclatura)\ntrain_dataloader = train_loader \nval_dataloader = val_loader\n\n# Dicionário para registrar o histórico exigido\nhistory = {\n    'train_loss': [],\n    'val_loss': [],\n    'val_iou': [],\n    'val_acc': []\n}\n\nprint(f\"🚀 Iniciando o treinamento no dispositivo: {device}\\n\")\n\n# ==========================================\n# 2. LAÇO PRINCIPAL (LOOP DE TREINAMENTO)\n# ==========================================\nfor epoch in range(num_epochs):\n    \n    # --------------------------------------\n    # FASE DE TREINAMENTO\n    # --------------------------------------\n    model.train()\n    running_train_loss = 0.0\n    \n    # tqdm exibe uma barra de progresso interativa\n    pbar_train = tqdm(train_dataloader, desc=f\"Época {epoch+1}/{num_epochs} [Treino]\")\n    for images, masks in pbar_train:\n        images = images.to(device)\n        masks = masks.to(device).long() # Garante o tipo correto para CrossEntropy Loss\n        \n        # Passo para frente (Forward)\n        optimizer.zero_grad()\n        outputs = model(images)\n        loss = criterion(outputs, masks)\n        \n        # Passo para trás e Otimização (Backward)\n        loss.backward()\n        optimizer.step()\n        \n        running_train_loss += loss.item() * images.size(0)\n        pbar_train.set_postfix({'loss': loss.item()})\n        \n    epoch_train_loss = running_train_loss / len(train_dataloader.dataset)\n    history['train_loss'].append(epoch_train_loss)\n    \n    # --------------------------------------\n    # FASE DE VALIDAÇÃO\n    # --------------------------------------\n    model.eval()\n    running_val_loss = 0.0\n    \n    # Variáveis para acumular métricas globais da época de validação\n    total_correct_pixels = 0\n    total_pixels = 0\n    total_intersection = torch.zeros(num_classes).to(device)\n    total_union = torch.zeros(num_classes).to(device)\n    \n    with torch.no_grad(): # Desativa gradientes para poupar memória RAM/VRAM\n        for images, masks in val_dataloader:\n            images = images.to(device)\n            masks = masks.to(device).long()\n            \n            outputs = model(images)\n            loss = criterion(outputs, masks)\n            running_val_loss += loss.item() * images.size(0)\n            \n            # Obter a classe predita (maior probabilidade no canal)\n            preds = torch.argmax(outputs, dim=1)\n            \n            # Acurácia por Pixel (Pixel Accuracy)\n            total_correct_pixels += (preds == masks).sum().item()\n            total_pixels += masks.numel()\n            \n            # Cálculo de Interseção e União para o IoU (por classe)\n            for cls in range(num_classes):\n                pred_cls = (preds == cls)\n                target_cls = (masks == cls)\n                total_intersection[cls] += (pred_cls & target_cls).sum().item()\n                total_union[cls] += (pred_cls | target_cls).sum().item()\n                \n    # Cálculo das médias finais da época de validação\n    epoch_val_loss = running_val_loss / len(val_dataloader.dataset)\n    epoch_val_acc = total_correct_pixels / total_pixels\n    \n    # Calcular o mIoU (Mean IoU) ignorando divisões por zero de classes ausentes no lote\n    ious = []\n    for cls in range(num_classes):\n        if total_union[cls] > 0:\n            ious.append((total_intersection[cls] / total_union[cls]).item())\n    \n    epoch_val_iou = np.mean(ious) if len(ious) > 0 else 0.0\n    \n    # Salva os registros exigidos no histórico\n    history['val_loss'].append(epoch_val_loss)\n    history['val_iou'].append(epoch_val_iou)\n    history['val_acc'].append(epoch_val_acc)\n    \n    # Exibe o sumário estruturado da época\n    print(f\"📢 [Época {epoch+1}] \"\n          f\"Loss Treino: {epoch_train_loss:.4f} | \"\n          f\"Loss Val: {epoch_val_loss:.4f} | \"\n          f\"mIoU Val: {epoch_val_iou:.4f} | \"\n          f\"Acurácia Pixel Val: {epoch_val_acc:.4f}\\n\")\n\nprint(\"✅ Treinamento finalizado com sucesso!\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **7. DATA AUGMENTATION**\n\nAplique Data Augmentation no conjunto de treino.\n\nSugestões de transformações:\n\n- espelhamento horizontal;\n- rotação pequena;\n- alteração de brilho;\n- alteração de contraste;\n- recorte aleatório.\n\nImportante:\nAs mesmas transformações aplicadas na imagem devem ser aplicadas também na máscara.\n\nObjetivo:\nAumentar a diversidade dos dados de treinamento e melhorar a generalização do modelo.","metadata":{}},{"cell_type":"code","source":"import torchvision.transforms.functional as TF\nimport random\nimport torch\n\nclass LoveDAAugmentation:\n    def __init__(self, crop_size=(256, 256)):\n        self.crop_size = crop_size\n\n    def __call__(self, image, mask):\n        # Nota: assume-se que 'image' e 'mask' já sejam tensores ou PIL Images antes das operações espaciais.\n        \n        # 1. Espelhamento Horizontal (Horizontal Flip)\n        if random.random() > 0.5:\n            image = TF.hflip(image)\n            mask = TF.hflip(mask)\n            \n        # 2. Rotação Pequena (Entre -15 e 15 graus)\n        if random.random() > 0.5:\n            angle = random.uniform(-15, 15)\n            image = TF.rotate(image, angle)\n            # CRÍTICO: Usar NEAREST para a máscara não corromper os rótulos das classes\n            mask = TF.rotate(mask, angle, interpolation=TF.InterpolationMode.NEAREST)\n            \n        # 3. Recorte Aleatório (Random Crop)\n        if random.random() > 0.5:\n            # Obtém os parâmetros do recorte baseando-se no tamanho da imagem\n            i, j, h, w = TF.RandomCrop.get_params(image, output_size=self.crop_size)\n            image = TF.crop(image, i, j, h, w)\n            mask = TF.crop(mask, i, j, h, w)\n            \n        # 4. Alteração de Brilho (APENAS NA IMAGEM)\n        if random.random() > 0.5:\n            brightness_factor = random.uniform(0.8, 1.2) # variação de 20%\n            image = TF.adjust_brightness(image, brightness_factor)\n            \n        # 5. Alteração de Contraste (APENAS NA IMAGEM)\n        if random.random() > 0.5:\n            contrast_factor = random.uniform(0.8, 1.2) # variação de 20%\n            image = TF.adjust_contrast(image, contrast_factor)\n            \n        return image, mask","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **8. AVALIAÇÃO NO CONJUNTO DE TESTE**\n\nApós o treinamento, aplique o modelo nas imagens de teste.\n\nPara pelo menos 5 imagens, apresente:\n\n1. imagem original;\n2. máscara real;\n3. máscara prevista pelo modelo;\n4. sobreposição da máscara prevista na imagem original.","metadata":{}},{"cell_type":"code","source":"import os\nimport torch\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom PIL import Image\nimport torchvision.transforms as transforms\n\ndef predict_and_display(image_path, model, device):\n    \"\"\"\n    Carrega uma imagem, realiza a inferência usando o modelo treinado\n    e exibe a imagem original ao lado da máscara predita.\n    \"\"\"\n    if not os.path.exists(image_path):\n        print(f\"Erro: O arquivo {image_path} não foi encontrado.\")\n        return\n\n    # 1. Carregar e pré-processar a imagem\n    img_org = Image.open(image_path).convert(\"RGB\")\n    \n    # Transformações necessárias para o modelo (ajuste o Resize se necessário)\n    transform = transforms.Compose([\n        transforms.Resize((512, 512)),\n        transforms.ToTensor(),\n        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n    ])\n    \n    input_tensor = transform(img_org).unsqueeze(0).to(device)\n\n    # 2. Executar a inferência\n    model.eval()\n    with torch.no_grad():\n        output = model(input_tensor)\n        # Caso o modelo retorne um dicionário (como os modelos do torchvision)\n        if isinstance(output, dict):\n            output = output['out']\n        \n        # Obter a classe com maior probabilidade para cada pixel\n        pred_mask = torch.argmax(output, dim=1).squeeze(0).cpu().numpy()\n\n    # 3. Plotar os resultados lado a lado\n    fig, axes = plt.subplots(1, 2, figsize=(12, 6))\n\n    axes[0].imshow(img_org)\n    axes[0].set_title(\"Imagem de Entrada\")\n    axes[0].axis('off')\n\n    # Usando um colormap qualitativo para diferenciar as classes do LoveDA\n    axes[1].imshow(pred_mask, cmap='tab10') \n    axes[1].set_title(\"Máscara Predita pelo Modelo\")\n    axes[1].axis('off')\n\n    plt.tight_layout()\n    plt.show()\n\n# --- Exemplo de Execução do Passo 8 ---\n# Defina o caminho da imagem que deseja testar\ntarget_image = '/kaggle/working/loveda_subset/train/images/1373.png'\n\n# Certifique-se de que a variável 'model' e 'device' estejam definidas no seu notebook\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\npredict_and_display(target_image, model, device)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# **9. ANÁLISE DOS RESULTADOS**\n\nAnalise visualmente os resultados obtidos.\n\nVerifique principalmente:\n\n- se as estradas foram identificadas corretamente;\n- se as construções foram identificadas corretamente;\n- se a vegetação foi separada das áreas agrícolas;\n- se água foi confundida com sombra;\n- se solo exposto foi confundido com estrada;\n- se construções pequenas foram detectadas;\n- se estradas estreitas foram perdidas;\n- se a segmentação ficou fragmentada ou contínua.","metadata":{}}]}